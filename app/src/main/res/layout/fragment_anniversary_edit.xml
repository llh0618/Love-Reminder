<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← 返回"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorPrimary"
                android:padding="8dp"
                android:clickable="true" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="编辑纪念日"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorOnBackground" />
            <TextView
                android:id="@+id/tv_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="保存"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:clickable="true" />
        </LinearLayout>

        <!-- Form fields -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="名称"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="日期（点击选择）"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:clickable="true"
            android:focusable="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Type chips -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="类型"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />
        <LinearLayout
            android:id="@+id/type_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_valentine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="情人节"
                    style="@style/Widget.Material3.Chip.Filter" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_520"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="520"
                    style="@style/Widget.Material3.Chip.Filter" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_qixi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="七夕"
                    style="@style/Widget.Material3.Chip.Filter" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_birthday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="生日"
                    style="@style/Widget.Material3.Chip.Filter" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_anniversary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="纪念日"
                    style="@style/Widget.Material3.Chip.Filter" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_relationship"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="确定关系"
                    style="@style/Widget.Material3.Chip.Filter" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_custom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自定义"
                    style="@style/Widget.Material3.Chip.Filter" />
            </LinearLayout>
        </LinearLayout>

        <!-- Milestones editor -->
        <LinearLayout
            android:id="@+id/layout_milestones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="里程碑天数"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:id="@+id/milestone_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:hint="天数"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_new_day"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>
                <Button
                    android:id="@+id/btn_add_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="添加"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.Material3.Button.TextButton" />
            </LinearLayout>
        </LinearLayout>

        <!-- Repeat -->
        <LinearLayout
            android:id="@+id/layout_repeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_repeat_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="重复"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant" />
            <RadioGroup
                android:id="@+id/rg_repeat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb_yearly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="每年"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/rb_once"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="仅此一次" />
            </RadioGroup>
        </LinearLayout>

        <!-- Remind -->
        <LinearLayout
            android:id="@+id/layout_remind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="提前提醒"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant" />
            <RadioGroup
                android:id="@+id/rg_remind"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb_day0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当天" />
                <RadioButton
                    android:id="@+id/rb_day3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="提前3天"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/rb_day7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="提前7天" />
            </RadioGroup>
        </LinearLayout>

        <!-- Note -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="备注"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Delete -->
        <Button
            android:id="@+id/btn_delete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="删除纪念日"
            android:textColor="?attr/colorError"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>
</ScrollView>
